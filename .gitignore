# Binaries for programs and plugins
*.exe
*.dll
*.so
*.dylib

# Test binary, build with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Dependency directories (remove the comment below if you use Go modules)
vendor/

# Go workspace file
*.code-workspace

# IDE specific files
.idea/
.vscode/

# OS generated files
.DS_Store

# Environment variables
.env

# Configuration files
.config.yaml
.config.*.yaml
!.config.example.yaml

# Logs
*.log

# Temporary files
./tmp
./tmp/*
*.tmp
*.temp

# Build directories
bin/
